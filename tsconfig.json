{
  "extends": "@tsconfig/svelte",
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src/ui/**/*", "vite.config.ts"],
  "exclude": ["src/plugin/**/*", "node_modules"]
}
